table ClusterMappingTable
	isHidden
	isPrivate
	lineageTag: 13ad0816-49b9-4057-963c-14f671b1d35e

	column Product
		lineageTag: 1737d7fe-ef04-4907-824d-9f18c9658a08
		summarizeBy: none
		isNameInferred
		sourceColumn: [Product]

