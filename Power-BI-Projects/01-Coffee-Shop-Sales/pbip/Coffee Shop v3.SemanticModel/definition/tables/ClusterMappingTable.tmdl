	partition ClusterMappingTable = calculated
		mode: import
		source = ```
				VAR __DS0FilterTable = 
					TREATAS({"June"}, 'Calendar'[Month Name Full])
				
				VAR __DS0Core = 
					SUMMARIZECOLUMNS(
						'DIM_Product'[Product],
						__DS0FilterTable,
						"AverageTransaction_Qty", CALCULATE(AVERAGE('FACT_Transaction'[Transaction Qty])),
						"Avg_Unit_Price", 'Measure'[Avg Unit Price]
					)
				
				VAR __DataTransformT0 = 
					KMeansClustering(
						SELECTCOLUMNS(
							__DS0Core,
							"Product", 'DIM_Product'[Product],
							"AverageTransaction_Qty", [AverageTransaction_Qty],
							"Avg_Unit_Price", [Avg_Unit_Price]
						),
						{("[AverageTransaction_Qty]", "Attribute"),
							("[Product]", "Item"),
							("[Avg_Unit_Price]", "Attribute")},
						{("[Product]", BLANK()),
							("ClusterId", "ClusterId")},
						4
					)
				
				RETURN __DataTransformT0
				```
			retainDataTillForceCalculate

	annotation ClusterMappingTable = true

	annotation __PBI_SemanticLinks = [{"LinkTarget":{"TableName":"DIM_Product","TableItemName":"Product (clusters)","ObjectType":4},"LinkType":"UsedInGroup"}]

